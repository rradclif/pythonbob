# Browser Automation Configuration
# Copy this file to .env and modify as needed

# Projector URLs
# Left Projector: http://192.168.1.21/PJControl.html
# Right Projector: http://192.168.1.20/PJControl.html
LEFT_PROJECTOR_URL=http://192.168.1.21/PJControl.html
RIGHT_PROJECTOR_URL=http://192.168.1.20/PJControl.html

# Browser Settings
HEADLESS=False
IMPLICIT_WAIT=10
PAGE_LOAD_TIMEOUT=30

# Screenshot Settings
SCREENSHOT_DIR=screenshots
SAVE_SCREENSHOTS=True

# Button Interaction Settings
WAIT_AFTER_CLICK=0.5
MAX_RETRIES=3
RETRY_DELAY=1.0

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=browser_automation.log